  "title": "Numerical Integration",
  "language": "python",
  "source": "def integrate(f, a, b, n=256):\n    dx = (b - a) / n\n    total = 0.0\n    for i in range(n):\n        x = a + (i + 0.5) * dx\n        total += f(x) * dx\n    return total\n",
